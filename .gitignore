# dependencies
/node_modules
/.venv-aws
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Flutter mobile app build artifacts
/flutter_app/build
/flutter_app/.dart_tool

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.vercel.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# studio uploads (served from /studio-assets when not using Vercel Blob)
/public/studio-assets/*
!/public/studio-assets/.gitkeep
.env*

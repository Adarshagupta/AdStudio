generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EmailTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum EmailChannel {
  AUTH
  INVITE
  MARKETING
  ADS
  REMINDER
  SYSTEM
}

enum EmailEventStatus {
  SENT
  FAILED
  SKIPPED
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum EmailAudience {
  WORKSPACE_MEMBERS
}

enum EmailReminderStatus {
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum GenerationFormat {
  UGC
  BRAIN_ROT
  STATIC
  REVIEW
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum BrandAssetType {
  LOGO
  PRODUCT_IMAGE
  FONT
}

enum MediaAssetKind {
  IMAGE
  AUDIO
  VIDEO
}

enum MediaAssetSource {
  UPLOADED
  GENERATED
}

enum SocialProvider {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  REDDIT
}

enum NotificationType {
  GENERATION_COMPLETE
  GENERATION_FAILED
  MEMBER_JOINED
  SYSTEM
}

enum StudioTemplateListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CompanySize {
  SIZE_1_5
  SIZE_6_50
  SIZE_51_100
  SIZE_100_PLUS
}

enum MonthlyAdSpend {
  UNDER_20K
  SPEND_20K_100K
  SPEND_100K_1M
  SPEND_1M_PLUS
}

model Workspace {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  plan             Plan          @default(FREE)
  stripeCustomerId          String?       @unique
  stripeSubscriptionId      String?       @unique
  billingInterval           String?
  subscriptionStatus        String?
  creditsRemaining          Int           @default(0)
  videoMinutesUsed          Int           @default(0)
  imageCountUsed            Int           @default(0)
  premiumCreditsUsed        Int           @default(0)
  welcomeCreditsClaimedAt   DateTime?
  paymentSetupSkippedAt     DateTime?
  paymentSetupCompletedAt   DateTime?
  agentBrandTone            String?
  agentTargetAudience       String?
  agentDefaultAspectRatio   String?
  createdAt                 DateTime      @default(now())
  members          WorkspaceMember[]
  generations      Generation[]
  longFormVideos   StudioLongFormVideo[]
  avatars          Avatar[]
  brandAssets      BrandAsset[]
  sessions           Session[]
  studioFlows        StudioFlow[]
  mediaAssets        UserMediaAsset[]
  socialConnections  SocialConnection[]
  invites            WorkspaceInvite[]
  emailEvents        EmailEvent[]
  emailTemplates     EmailTemplate[]
  emailCampaigns     EmailCampaign[]
  emailReminders     EmailReminder[]
  lastWorkspaceUsers User[]            @relation("UserLastWorkspace")
  onboarding         WorkspaceOnboarding?
  notifications      Notification[]
  templateListings   StudioTemplateListing[]
  templatePurchases  StudioTemplatePurchase[]
  referralRewardsGranted ReferralReward[] @relation("ReferrerWorkspaceRewards")
  referralRewardsFrom    ReferralReward[] @relation("ReferredWorkspaceRewards")
}

model User {
  id               String       @id @default(cuid())
  clerkId          String?      @unique
  email            String       @unique
  name             String?
  passwordHash     String?
  lastWorkspaceId  String?
  isActive         Boolean      @default(true)
  emailVerifiedAt  DateTime?
  createdAt        DateTime     @default(now())
  lastWorkspace    Workspace?   @relation("UserLastWorkspace", fields: [lastWorkspaceId], references: [id])
  memberships      WorkspaceMember[]
  generations      Generation[]
  longFormVideos   StudioLongFormVideo[]
  sessions         Session[]
  studioFlows      StudioFlow[]
  mediaAssets      UserMediaAsset[]
  sentWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInvitesSent")
  emailTokens      EmailToken[]
  emailPreference  EmailPreference?
  emailEvents      EmailEvent[]
  createdEmailCampaigns EmailCampaign[]
  receivedEmailReminders EmailReminder[] @relation("EmailReminderRecipient")
  createdEmailReminders EmailReminder[] @relation("EmailReminderCreator")
  notifications         Notification[]
  publishedTemplates    StudioTemplateListing[]
  templatePurchases     StudioTemplatePurchase[]
  referralCode          String?          @unique
  referredByUserId        String?
  referredBy              User?            @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals               User[]           @relation("UserReferrals")
  referralRewardsEarned   ReferralReward[] @relation("ReferralRewardsEarned")
  referralRewardsTriggered ReferralReward[] @relation("ReferralRewardsTriggered")

  @@index([lastWorkspaceId])
  @@index([emailVerifiedAt])
  @@index([referredByUserId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(MEMBER)
  permissions Json      @default("{}")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, isActive])
  @@index([userId, isActive])
}

model Session {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  workspaceId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model Generation {
  id           String           @id @default(cuid())
  workspaceId  String
  userId       String
  format       GenerationFormat
  status       GenerationStatus @default(QUEUED)
  prompt       String
  productUrl   String?
  scriptText   String?
  avatarId     String?
  xaiRequestId String?
  errorMessage String?
  style        Json?
  videoUrl     String?
  thumbnailUrl String?
  durationSec  Int?
  renderTimeMs Int?
  createdAt    DateTime         @default(now())
  startedAt     DateTime?
  completedAt  DateTime?
  workspace    Workspace        @relation(fields: [workspaceId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([userId])
  @@index([xaiRequestId])
}

model StudioLongFormVideo {
  id                String                  @id @default(cuid())
  workspaceId       String
  userId            String
  studioFlowId      String?
  title             String                  @default("Long-form video")
  prompt            String?
  targetDurationSec Int?
  status            GenerationStatus        @default(QUEUED)
  settings          Json                    @default("{}")
  finalVideoUrl     String?
  thumbnailUrl      String?
  errorMessage      String?
  renderTimeMs      Int?
  createdAt         DateTime                @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  workspace         Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments          StudioLongFormSegment[]

  @@index([workspaceId, createdAt])
  @@index([userId])
  @@index([studioFlowId])
}

model StudioLongFormSegment {
  id              String              @id @default(cuid())
  longFormVideoId String
  generationId    String?
  nodeId          String?
  index           Int
  title           String
  prompt          String?
  status          GenerationStatus    @default(QUEUED)
  videoUrl        String?
  durationSec     Int?
  errorMessage    String?
  createdAt       DateTime            @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  longFormVideo   StudioLongFormVideo @relation(fields: [longFormVideoId], references: [id], onDelete: Cascade)

  @@unique([longFormVideoId, index])
  @@index([generationId])
  @@index([nodeId])
}

model Avatar {
  id          String    @id @default(cuid())
  workspaceId String?
  name        String
  previewUrl  String
  isSystem    Boolean   @default(false)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model BrandAsset {
  id          String         @id @default(cuid())
  workspaceId String
  type        BrandAssetType
  url         String
  name        String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model WorkspaceInvite {
  id          String                @id @default(cuid())
  workspaceId String
  invitedById String
  email       String
  name        String?
  role        Role                  @default(MEMBER)
  permissions Json                  @default("{}")
  tokenHash   String                @unique
  status      WorkspaceInviteStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime              @default(now())
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User                  @relation("WorkspaceInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([email])
  @@index([expiresAt])
}

model EmailToken {
  id        String         @id @default(cuid())
  userId    String
  email     String
  type      EmailTokenType
  tokenHash String         @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([email, type])
  @@index([expiresAt])
}

model EmailPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  marketingEnabled      Boolean  @default(true)
  adsEnabled            Boolean  @default(true)
  remindersEnabled      Boolean  @default(true)
  productUpdatesEnabled Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailEvent {
  id                String           @id @default(cuid())
  workspaceId       String?
  userId            String?
  toEmail           String
  fromEmail         String
  subject           String
  channel           EmailChannel
  status            EmailEventStatus
  provider          String
  providerMessageId String?
  errorMessage      String?
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now())
  sentAt            DateTime?
  workspace         Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([channel, createdAt])
  @@index([status, createdAt])
}

model EmailTemplate {
  id          String       @id @default(cuid())
  workspaceId String?
  key         String
  channel     EmailChannel
  name        String
  subject     String
  previewText String?
  textBody    String
  htmlBody    String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId, channel])
}

model EmailCampaign {
  id          String              @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  channel     EmailChannel
  audience    EmailAudience       @default(WORKSPACE_MEMBERS)
  subject     String
  textBody    String
  htmlBody    String?
  status      EmailCampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User                @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, scheduledAt])
}

model EmailReminder {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String?
  createdById String
  title       String
  message     String
  sendAt      DateTime
  status      EmailReminderStatus @default(SCHEDULED)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?               @relation("EmailReminderRecipient", fields: [userId], references: [id], onDelete: SetNull)
  createdBy   User                @relation("EmailReminderCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, sendAt])
  @@index([userId, sendAt])
}

model UserMediaAsset {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String
  kind        MediaAssetKind
  source      MediaAssetSource
  url         String
  name        String?
  mimeType    String?
  width       Int?
  height      Int?
  durationSec Int?
  byteSize    Int?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, kind, createdAt])
  @@index([workspaceId, createdAt])
}

model StudioFlow {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String    @default("Untitled flow")
  nodes       Json      @default("[]")
  edges       Json      @default("[]")
  viewport    Json      @default("{}")
  agentChat   Json      @default("{\"messages\":[],\"requestHistory\":[],\"updatedAt\":\"\"}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, updatedAt])
  @@index([userId])
}

model StudioTemplateListing {
  id                   String                      @id @default(cuid())
  slug                 String                      @unique
  title                String
  description          String                      @default("")
  previewImageUrl      String?
  sampleOutputs        Json                        @default("[]")
  priceCents           Int                         @default(0)
  currency             String                      @default("usd")
  status               StudioTemplateListingStatus @default(DRAFT)
  publisherUserId      String
  publisherWorkspaceId String
  sourceFlowId         String?
  nodes                Json                        @default("[]")
  edges                Json                        @default("[]")
  viewport             Json                        @default("{}")
  category             String?
  tags                 Json                        @default("[]")
  useCount             Int                         @default(0)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  publisherUser        User                        @relation(fields: [publisherUserId], references: [id], onDelete: Cascade)
  publisherWorkspace   Workspace                   @relation(fields: [publisherWorkspaceId], references: [id], onDelete: Cascade)
  purchases            StudioTemplatePurchase[]

  @@index([status, createdAt])
  @@index([publisherWorkspaceId, status])
  @@index([category])
}

model StudioTemplatePurchase {
  id                      String                @id @default(cuid())
  workspaceId             String
  listingId               String
  purchasedByUserId       String
  stripeCheckoutSessionId String                @unique
  stripePaymentIntentId   String?
  amountCents             Int
  currency                String                @default("usd")
  createdAt               DateTime              @default(now())
  workspace               Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  listing                 StudioTemplateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  purchasedByUser         User                  @relation(fields: [purchasedByUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, listingId])
  @@index([listingId])
  @@index([workspaceId])
}

model WorkspaceOnboarding {
  id              String          @id @default(cuid())
  workspaceId     String          @unique
  companyName     String?
  companySize     CompanySize?
  monthlyAdSpend  MonthlyAdSpend?
  hearAboutSource String?
  hearAboutOther  String?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String
  type        NotificationType
  title       String
  message     String
  href        String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([workspaceId, createdAt])
}

model SocialConnection {
  id              String         @id @default(cuid())
  workspaceId     String
  provider        SocialProvider
  externalId      String
  username        String?
  displayName     String?
  avatarUrl       String?
  accessTokenEnc  String
  refreshTokenEnc String?
  expiresAt       DateTime?
  scopes          String[]
  profileMeta     Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model Model {
  id               String   @id @default(cuid())
  name             String
  provider         String   @unique
  category         String
  isPremium        Boolean  @default(false)
  usesIncludedQuota Boolean @default(true)
  cost             Int      @default(1)
  description      String   @default("")
  isActive         Boolean  @default(true)
  isSystem         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([isSystem])
}

model ReferralReward {
  id                      String    @id @default(cuid())
  referrerUserId          String
  referrerWorkspaceId     String
  referredUserId          String    @unique
  referredWorkspaceId     String
  stripeCheckoutSessionId String?   @unique
  stripeSubscriptionId    String?   @unique
  plan                    Plan
  creditsAwarded          Int
  createdAt               DateTime  @default(now())

  referrerUser      User      @relation("ReferralRewardsEarned", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUser      User      @relation("ReferralRewardsTriggered", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrerWorkspace Workspace @relation("ReferrerWorkspaceRewards", fields: [referrerWorkspaceId], references: [id], onDelete: Cascade)
  referredWorkspace Workspace @relation("ReferredWorkspaceRewards", fields: [referredWorkspaceId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([referrerWorkspaceId])
}

model BlogPost {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  excerpt       String         @default("")
  content       String         @default("")
  coverImageUrl String?
  authorName    String?
  status        BlogPostStatus @default(DRAFT)
  tags          Json           @default("[]")
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, publishedAt])
}

# Studio Pro realtime — Cloudflare Worker + Durable Objects (WebSocket)
# Deploy with: bun run deploy:realtime
NEXT_PUBLIC_STUDIO_REALTIME_URL="https://ugc-studio-realtime.your-subdomain.workers.dev"
# Shared secret between Vercel and the Cloudflare worker (auto-generated on first deploy)
STUDIO_REALTIME_JWT_SECRET="replace-with-a-long-random-secret"

# Vercel KV (Upstash Redis via Marketplace) — serverless cache for fast page navigation
# Install: Vercel Dashboard → Storage → Upstash Redis → Connect to project
# Auto-provisions UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN (or KV_REST_API_*)
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Optional: Redis TCP URL from the same Upstash database — BullMQ queue + SSE pub/sub fan-out
REDIS_URL="rediss://default:your-upstash-token@your-endpoint.upstash.io:6379"

# PostgreSQL (Prisma) — required for auth, onboarding, and dashboard
# Local: copy this file to `.env`. Vercel + Neon may also set POSTGRES_PRISMA_URL automatically.
# Use Neon *pooler* URL for the app (note -pooler in hostname)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15"
# Neon *direct* URL (no -pooler) — required for `bun run db:migrate`
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Cloudflare Workers AI — create token at https://dash.cloudflare.com/?to=/:account/ai/workers-ai
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# Fireworks.ai — text generation for scripts, chat, and Studio Pro text nodes
FIREWORKS_API_KEY=""
FIREWORKS_TEXT_MODEL="accounts/fireworks/models/kimi-k2p6"

# Free Workers AI models (@cf/ — daily neuron quota)
CF_IMAGE_MODEL="@cf/stabilityai/stable-diffusion-xl-base-1.0"
CF_AUDIO_MODEL="@cf/myshell-ai/melotts"

# Paid partner models need AI Gateway credits — https://dash.cloudflare.com/?to=/:account/ai/ai-gateway
# CF_VIDEO_MODEL="vidu/q3-turbo"

# OpenAI — optional premium image + video (DALL·E 3, GPT Image, Sora)
OPENAI_API_KEY=""
# OPENAI_IMAGE_MODEL="openai/dall-e-3"
# OPENAI_VIDEO_MODEL="openai/sora-2"

# SylicaAI — Flux Schnell image generation (https://image.sylicaai.com/)
SYLICAAI_IMAGE_API_KEY="change-this-to-your-secret-key"

# LTX — video generation (https://console.ltx.video)
LTX_API_KEY=""
# Comma-separated fallback keys — tried in order when primary is rate-limited or out of credits
LTX_API_KEYS=""
# Default model when no image/video is connected (ltx-2-3-fast or ltx-2-3-pro)
LTX_VIDEO_MODEL="ltx-2-3-fast"
# Studio auto-picks image-to-video, retake, or extend when upstream media is connected.

# Studio long-form export — required on the server that assembles completed clips into one MP4.
# Leave unset when `ffmpeg` is available on PATH; otherwise point at the binary.
# FFMPEG_PATH="/usr/local/bin/ffmpeg"

# Studio uploads — Cloudflare R2 in production (Vercel); local dev uses public/studio-assets unless STUDIO_STORAGE=r2
# Put real values in `.env` only (never commit secrets). Copy this block as a template.
# Account ID: Cloudflare dashboard → R2 → right sidebar (32-char hex)
R2_ACCOUNT_ID="your-cloudflare-account-id"
# API token: R2 → Manage R2 API Tokens → Object Read & Write → scope to your bucket
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="studio"
# Public URL for browser/media links — NOT the S3 API host (*.r2.cloudflarestorage.com).
# R2 bucket → Settings → Public access → enable → use the https://pub-xxxx.r2.dev URL (or a custom domain).
R2_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"
# Optional: use R2 for uploads in local dev too
# STUDIO_STORAGE="r2"
# Optional: browser → R2 direct upload (needs CORS — paste scripts/r2-cors-policy.json in bucket Settings → CORS)
# STUDIO_UPLOAD_DIRECT="1"

# Stripe — template marketplace checkout (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Fallback app URL when no request context (cron, workers). Email links prefer the site you sent from.
# On Vercel, VERCEL_URL is used automatically if APP_URL is unset.
APP_URL="http://localhost:3000"

# Email provider — smtp or cloudflare
EMAIL_PROVIDER="smtp"

# SMTP email provider — Brevo, Resend SMTP, SendGrid SMTP, Mailgun SMTP, etc.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="true"
SMTP_USER="your-smtp-login"
SMTP_PASS="your-smtp-password-or-api-key"

# Optional Cloudflare Email Service REST fallback
CLOUDFLARE_EMAIL_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""

EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Ad Studio"
EMAIL_REPLY_TO="support@yourdomain.com"
EMAIL_REPLY_TO_NAME="Support"

# Optional secret for /api/email/dispatch-due cron calls
EMAIL_CRON_SECRET="replace-with-a-random-cron-secret"
# Vercel Cron also supports CRON_SECRET; either secret is accepted by the route.
CRON_SECRET="replace-with-a-random-cron-secret"

# Admin credentials — used by /admin login. If unset, falls back to hardcoded values.
ADMIN_EMAIL="adarsh@sylicaai.com"
ADMIN_PASSWORD="adarsh@8"

# Social integrations — encrypt stored OAuth tokens (32+ char random string)
SOCIAL_TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-secret"
SOCIAL_OAUTH_STATE_SECRET="replace-with-another-long-random-secret"

# Meta (Instagram + Facebook) — https://developers.facebook.com/
META_APP_ID=""
META_APP_SECRET=""

# TikTok — https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Reddit — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
SYLICAAI_IMAGE_API_KEY="change-this-to-your-secret-key"
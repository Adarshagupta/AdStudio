{
  "name": "ugc-ad-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "build": "prisma generate && node scripts/generate-pwa-icons.mjs && next build",
    "db:migrate": "node scripts/ensure-direct-database-url.mjs && prisma migrate deploy",
    "deploy": "node scripts/sync-vercel-env.mjs && vercel deploy --prod --yes",

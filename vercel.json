{
  "buildCommand": "node scripts/migrate-deploy.mjs && prisma generate && next build",
  "framework": "nextjs",
  "functions": {
    "src/app/api/studio/image/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate/*/status/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/email/dispatch-due",
      "schedule": "0 0 * * *"
    }
  ]
}

# LiteMoov Flutter API configuration
#
# Production (default when .env is missing or on release builds):
#   https://www.litemoov.com/api
#
# --- Local development (same Wi‑Fi as your PC) ---
# API_ENV=development
# API_BASE_URL=http://YOUR_PC_IP:3000/api
#
# Emulator loopback:
# API_BASE_URL=http://10.0.2.2:3000/api
#
# --- Force production while debugging ---
# API_ENV=production
#
# Or pass at build/run time:
# flutter run --dart-define=API_BASE_URL=https://www.litemoov.com/api

API_ENV=development
API_BASE_URL=http://192.168.1.68:3000/api
